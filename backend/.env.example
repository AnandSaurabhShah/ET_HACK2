AEGIS_ENV=production
AEGIS_DATABASE_URL=postgresql+psycopg://aegis:aegis@postgres:5432/aegis
AEGIS_API_KEY=change-me-long-random-secret
AEGIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AEGIS_INGEST_RATE_LIMIT_PER_MINUTE=6000
AEGIS_HIGH_BLAST_RADIUS_THRESHOLD=6
AEGIS_PERIMETER_BLOCK_COOLDOWN_SECONDS=900
AEGIS_DEMO_BACKGROUND_ENABLED=false
AEGIS_PREDICTIVE_RISK_THRESHOLD=0.58
AEGIS_GENAI_PROVIDER=offline
AEGIS_GENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
AEGIS_GENAI_MODEL=gpt-4.1-mini
AEGIS_GENAI_API_KEY=
AEGIS_GENAI_TIMEOUT_SECONDS=8
